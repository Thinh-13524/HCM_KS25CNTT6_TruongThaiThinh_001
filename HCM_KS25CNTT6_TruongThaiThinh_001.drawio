        <mxCell id="ZMSBTiZpAtYYZfXQ6_ch-6" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Phân tích lỗi&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Vấn đề: chỉ dùng Fullname&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Ví dụ:&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Nguyễn Văn A (SV1)&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Nguyễn Văn A (SV2)&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Trong hệ thống:&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;2 người này bị coi là 1 người&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Hậu quả:&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;1. Mất Entity Integrity (toàn vẹn thực thể)&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Mỗi thực thể phải có 1 định danh duy nhất&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Nhưng:&amp;nbsp; Fullname không unique, không phân biệt được từng sinh viên&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;2. Sai lệch dữ liệu&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Ví dụ:&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;SV1 mượn sách&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;SV2 trả sách&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Hệ thống hiểu:&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;-&amp;gt; cùng 1 người mượn rồi trả&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Sai hoàn toàn lịch sử&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;3. Không truy vết được&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Không biết ai đang giữ sách&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;Không biết ai vi phạm&lt;/p&gt;&lt;p data-start=&quot;44&quot; data-end=&quot;113&quot;&gt;-&amp;gt; Hệ thống quản lý mất giá trị&lt;/p&gt;" vertex="1">
          <mxGeometry height="590" width="565" x="190" y="420" as="geometry" />
        </mxCell>
